NODE_ENV=production
API_PORT=4000

# Public URLs
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
ADMIN_WEB_URL=https://admin.example.com
CUSTOMER_WEB_URL=https://portal.example.com
PUBLIC_API_URL=https://api.example.com
ALLOWED_ORIGINS=https://admin.example.com,https://portal.example.com

# Database: PostgreSQL only for real production
DATABASE_URL="postgresql://phone_finance:change_this_password@postgres:5432/phone_finance?schema=public"

# Auth: bootstrap owner admin with pnpm bootstrap:prod
JWT_SECRET="replace_with_64_plus_char_random_secret"
ORG_NAME="Your Company Co., Ltd."
ORG_ID="default_org"
ORG_TAX_ID=""
ORG_PHONE=""
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="replace_with_12_plus_chars_or_more"
ADMIN_NAME="Owner Admin"

# Payment provider. /payments/webhook is ready; set secret in gateway webhook headers.
PAYMENT_PROVIDER="webhook"
PROMPTPAY_ID=""
DEFAULT_PROMPTPAY_ID=""
PORTAL_LEGACY_LOOKUP_ENABLED="false"
PAYMENT_WEBHOOK_SECRET="replace_with_random_payment_webhook_secret"
SLIP_VERIFY_PROVIDER="manual"
SLIP_VERIFY_API_KEY=""

# Notifications: webhook or line recommended before go-live
NOTIFICATION_PROVIDER="webhook"
NOTIFICATION_WEBHOOK_URL="https://your-notification-worker.example.com/send"
NOTIFICATION_WEBHOOK_SECRET="replace_with_random_notification_secret"
LINE_CHANNEL_ACCESS_TOKEN=""
SMS_PROVIDER=""
SMS_PROVIDER_KEY=""
EMAIL_FROM="noreply@example.com"
SMTP_URL=""

# Storage. Prefer private bucket + signed URLs for sensitive slips/documents.
UPLOAD_DIR="/opt/koga/uploads"
PUBLIC_UPLOAD_BASE_URL="https://api.example.com/uploads"
MAX_UPLOAD_BYTES="8000000"
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="phone-finance"
S3_PUBLIC_BASE_URL=""

# Real device-control routing
DEVICE_CONTROL_PROVIDER="dual"
DEVICE_CONTROL_DRY_RUN="false"
DEVICE_CONTROL_MODE="LEASE_TO_OWN_ASSET_PROTECTION"
DEVICE_CONTROL_WEBHOOK_SECRET="replace_with_device_control_webhook_secret"
CRON_SECRET="replace_with_random_cron_secret"
BUSINESS_MODEL="LEASE_TO_OWN"

# Android Management API / Android Enterprise
ANDROID_MANAGEMENT_PROJECT_ID="your-google-cloud-project-id"
ANDROID_MANAGEMENT_ENTERPRISE_NAME="enterprises/LCxxxxxxxx"
ANDROID_MANAGEMENT_SERVICE_ACCOUNT_JSON="/opt/koga/certs/google-service-account.json"
ANDROID_MANAGEMENT_CALLBACK_URL="https://api.example.com/mdm/android/signup-callback"
ANDROID_MANAGEMENT_WEBHOOK_SECRET="replace_with_android_webhook_secret"
ANDROID_MANAGEMENT_DEFAULT_POLICY="lease-basic"
ANDROID_ENROLLMENT_TOKEN_DURATION="86400s"
ANDROID_ENROLLMENT_ONE_TIME_ONLY="true"

# Apple MDM / Apple Business Manager / ADE
APPLE_MDM_BASE_URL="https://api.example.com"
APPLE_MDM_APNS_CERT_PATH="/opt/koga/certs/apple-mdm-apns.pem"
APPLE_MDM_APNS_KEY_PATH="/opt/koga/certs/apple-mdm-apns-key.pem"
APPLE_MDM_APNS_TOPIC="com.apple.mgmt.External.xxxxx"
APPLE_MDM_APNS_HOST="https://api.push.apple.com"
APPLE_ABM_SERVER_TOKEN_PATH="/opt/koga/certs/apple-abm-server-token.p7m"
APPLE_MDM_PROFILE_SIGNING_CERT_PATH="/opt/koga/certs/profile-signing.pem"
APPLE_MDM_PROFILE_SIGNING_KEY_PATH="/opt/koga/certs/profile-signing-key.pem"
APPLE_MDM_CHECKIN_URL="https://api.example.com/mdm/apple/checkin"
APPLE_MDM_SERVER_URL="https://api.example.com/mdm/apple/connect"

# SaaS platform mode
STORE_TRIAL_DAYS=14
PUBLIC_STORE_SIGNUP_URL="https://admin.yourdomain.com/signup"
PLATFORM_OWNER_DASHBOARD_URL="https://admin.yourdomain.com/platform"

# Final production integration switches
STORAGE_PROVIDER="local" # local|s3|r2|supabase
STORAGE_BUCKET=""
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
SLIP_VERIFICATION_PROVIDER="manual" # manual|webhook|bank_api
SLIP_VERIFICATION_WEBHOOK_URL=""
PAYMENT_GATEWAY_PROVIDER="manual" # manual|omise|gbprimepay|2c2p|scb_bill_payment|webhook
PAYMENT_GATEWAY_WEBHOOK_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
SMS_PROVIDER="disabled" # disabled|webhook|thaibulksms|twilio
SMS_WEBHOOK_URL=""
PLATFORM_MDM_SCOPE="PLATFORM_OWNED_SINGLE_ENTERPRISE"
ENABLE_CUSTOMER_PORTAL="true"
ENABLE_ICLOUD_CUSTODY="true"
ENABLE_MDM_ANDROID="false"
ENABLE_MDM_APPLE="false"
ENABLE_PAYMENT_AUTO_VERIFY="false"

# External integration production keys added in external-ready pack
OMISE_PUBLIC_KEY=""
OMISE_SECRET_KEY=""
GBPRIMEPAY_MERCHANT_ID=""
GBPRIMEPAY_PUBLIC_KEY=""
GBPRIMEPAY_SECRET_KEY=""
TWOC2P_MERCHANT_ID=""
TWOC2P_SECRET_KEY=""
SCB_BILLER_ID=""
SCB_API_KEY=""
SLIP_VERIFICATION_WEBHOOK_SECRET=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
