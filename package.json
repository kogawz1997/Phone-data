{
  "name": "phone-finance-mdm-saas-external-ready",
  "private": true,
  "version": "1.0.0-external-ready",
  "description": "External-ready multi-tenant lease-to-own phone SaaS with production integration hub for payment, storage, notifications, MDM, and iCloud custody.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:api": "pnpm --filter @koga/api dev",
    "dev:admin": "pnpm --filter @koga/admin-web dev",
    "dev:customer": "pnpm --filter @koga/customer-web dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "db:seed": "pnpm --filter @repo/db db:seed",
    "db:generate:postgres": "pnpm --filter @repo/db db:generate:postgres",
    "db:migrate:postgres": "pnpm --filter @repo/db db:migrate:postgres",
    "db:push:postgres": "pnpm --filter @repo/db db:push:postgres",
    "db:studio:postgres": "pnpm --filter @repo/db db:studio:postgres",
    "mvp:reset": "pnpm --filter @repo/db db:reset && pnpm db:seed",
    "setup:local": "pnpm install && pnpm db:generate && pnpm db:push && pnpm bootstrap:prod",
    "setup:railway:first": "pnpm db:generate:postgres && pnpm db:push:postgres && pnpm bootstrap:prod",
    "setup:railway:migrate": "pnpm db:generate:postgres && pnpm db:migrate:postgres && pnpm bootstrap:prod",
    "bootstrap:prod": "pnpm --filter @repo/db bootstrap:prod",
    "setup:prod": "pnpm install && pnpm db:generate && pnpm db:push && pnpm bootstrap:prod && pnpm check:env && pnpm check:mdm && pnpm doctor:prod",
    "smoke:api": "node ./scripts/smoke-api.mjs",
    "check:env": "node ./scripts/check-env.mjs",
    "ready:check": "pnpm check:env && pnpm check:mdm && pnpm doctor:prod",
    "check:mdm": "node ./scripts/check-mdm-env.mjs",
    "db:seed:sample": "pnpm --filter @repo/db db:seed:sample",
    "doctor:prod": "node ./scripts/production-doctor.mjs",
    "create:env": "node ./scripts/create-env.mjs",
    "tenant:check": "node ./scripts/tenant-isolation-check.mjs",
    "go-live:check": "node ./scripts/go-live-master-check.mjs",
    "final:check": "pnpm ready:check && pnpm tenant:check && pnpm go-live:check && pnpm arch:check && pnpm external:check && pnpm deploy:check",
    "route:inventory": "node ./scripts/api-route-inventory.mjs",
    "arch:check": "node ./scripts/architecture-check.mjs",
    "external:check": "node ./scripts/external-integration-check.mjs",
    "deploy:check": "node ./scripts/deploy-pack-check.mjs",
    "deploy:prod": "bash ./infra/scripts/deploy.sh",
    "deploy:update": "bash ./infra/scripts/update.sh",
    "logs:prod": "bash ./infra/scripts/logs.sh",
    "backup:prod": "bash ./infra/scripts/backup.sh"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
