{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:push": "prisma db push --schema ./prisma/schema.prisma",
    "db:studio": "prisma studio --schema ./prisma/schema.prisma",
    "db:seed": "tsx ./prisma/seed.ts",
    "bootstrap:prod": "tsx ./prisma/bootstrap-production.ts",
    "db:reset": "rm -f ./prisma/dev.db ./prisma/dev.db-journal && prisma db push --schema ./prisma/schema.prisma --force-reset",
    "db:generate:postgres": "prisma generate --schema ./prisma/schema.postgres.prisma",
    "db:push:postgres": "prisma db push --schema ./prisma/schema.postgres.prisma",
    "db:studio:postgres": "prisma studio --schema ./prisma/schema.postgres.prisma",
    "db:seed:sample": "tsx ./prisma/seed.sample.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx ./prisma/seed.ts"
  }
}