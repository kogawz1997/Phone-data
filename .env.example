# App
NODE_ENV=development
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://147.50.253.50:4000
ADMIN_WEB_URL=http://147.50.253.50:3000
CUSTOMER_WEB_URL=http://147.50.253.50:3002
PUBLIC_API_URL=http://147.50.253.50:4000
ALLOWED_ORIGINS=http://147.50.253.50:3000,http://147.50.253.50:3002

# Local database. Production should use PostgreSQL and .env.production.example.
DATABASE_URL="file:./dev.db"

# Auth / organization bootstrap. Run: pnpm create:env OR fill these values manually.
JWT_SECRET="replace-with-long-random-secret"
ORG_NAME="KOGA Lease MDM"
ORG_ID="default_org"
ORG_TAX_ID=""
ORG_PHONE=""
ADMIN_EMAIL="owner@local.test"
ADMIN_PASSWORD="replace-with-12-plus-chars"
ADMIN_NAME="Owner Admin"

# Payments. Manual works now; webhook/gateway is ready through /payments/webhook.
PAYMENT_PROVIDER="manual"
PROMPTPAY_ID=""
DEFAULT_PROMPTPAY_ID=""
PORTAL_LEGACY_LOOKUP_ENABLED="false"
PAYMENT_WEBHOOK_SECRET="replace-with-payment-webhook-secret"
SLIP_VERIFY_PROVIDER="manual"
SLIP_VERIFY_API_KEY=""

# Notifications: local | webhook | line
NOTIFICATION_PROVIDER="local"
NOTIFICATION_WEBHOOK_URL=""
NOTIFICATION_WEBHOOK_SECRET="replace-with-notification-secret"
LINE_CHANNEL_ACCESS_TOKEN=""
SMS_PROVIDER=""
SMS_PROVIDER_KEY=""
EMAIL_FROM=""
SMTP_URL=""

# Storage. Local upload endpoint is ready; use private S3/R2 in production.
UPLOAD_DIR="./uploads"
PUBLIC_UPLOAD_BASE_URL="http://147.50.253.50:4000/uploads"
MAX_UPLOAD_BYTES="8000000"
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_PUBLIC_BASE_URL=""

# Device control provider: mock for local, android/apple/dual for real integrations.
DEVICE_CONTROL_PROVIDER="mock"
DEVICE_CONTROL_DRY_RUN="true"
CRON_SECRET="replace-with-cron-secret"
BUSINESS_MODEL="LEASE_TO_OWN"
DEVICE_CONTROL_MODE="LEASE_TO_OWN_ASSET_PROTECTION"
DEVICE_CONTROL_WEBHOOK_SECRET="replace-with-device-control-webhook-secret"

# Android Management API / Android Enterprise
ANDROID_MANAGEMENT_PROJECT_ID=""
ANDROID_MANAGEMENT_ENTERPRISE_NAME=""
ANDROID_MANAGEMENT_SERVICE_ACCOUNT_JSON="./certs/google-service-account.json"
ANDROID_MANAGEMENT_CALLBACK_URL="http://147.50.253.50:4000/mdm/android/signup-callback"
ANDROID_MANAGEMENT_WEBHOOK_SECRET="replace-with-android-webhook-secret"
ANDROID_MANAGEMENT_DEFAULT_POLICY="lease-basic"
ANDROID_ENROLLMENT_TOKEN_DURATION="86400s"
ANDROID_ENROLLMENT_ONE_TIME_ONLY="true"

# Apple MDM / Apple Business Manager / ADE
APPLE_MDM_BASE_URL="http://147.50.253.50:4000"
APPLE_MDM_APNS_CERT_PATH="./certs/apple-mdm-apns.pem"
APPLE_MDM_APNS_KEY_PATH="./certs/apple-mdm-apns-key.pem"
APPLE_MDM_APNS_TOPIC=""
APPLE_MDM_APNS_HOST="https://api.push.apple.com"
APPLE_ABM_SERVER_TOKEN_PATH="./certs/apple-abm-server-token.p7m"
APPLE_MDM_PROFILE_SIGNING_CERT_PATH="./certs/profile-signing.pem"
APPLE_MDM_PROFILE_SIGNING_KEY_PATH="./certs/profile-signing-key.pem"
APPLE_MDM_CHECKIN_URL="http://147.50.253.50:4000/mdm/apple/checkin"
APPLE_MDM_SERVER_URL="http://147.50.253.50:4000/mdm/apple/connect"

# SaaS platform mode
STORE_TRIAL_DAYS=14
PUBLIC_STORE_SIGNUP_URL="http://147.50.253.50:3000/signup"
PLATFORM_OWNER_DASHBOARD_URL="http://147.50.253.50:3000/platform"

# Final production integration switches
STORAGE_PROVIDER="local" # local|s3|r2|supabase
STORAGE_BUCKET=""
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
SLIP_VERIFICATION_PROVIDER="manual" # manual|webhook|bank_api
SLIP_VERIFICATION_WEBHOOK_URL=""
PAYMENT_GATEWAY_PROVIDER="manual" # manual|omise|gbprimepay|2c2p|scb_bill_payment|webhook
PAYMENT_GATEWAY_WEBHOOK_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
SMS_PROVIDER="disabled" # disabled|webhook|thaibulksms|twilio
SMS_WEBHOOK_URL=""
PLATFORM_MDM_SCOPE="PLATFORM_OWNED_SINGLE_ENTERPRISE"
ENABLE_CUSTOMER_PORTAL="true"
ENABLE_ICLOUD_CUSTODY="true"
ENABLE_MDM_ANDROID="false"
ENABLE_MDM_APPLE="false"
ENABLE_PAYMENT_AUTO_VERIFY="false"

