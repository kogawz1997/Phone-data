# =========================
# KOGA Lease MDM SaaS Production Env
# =========================
NODE_ENV=production

# Domains. Point these DNS records to your VPS IP before running Caddy.
APP_DOMAIN=app.example.com
CUSTOMER_DOMAIN=customer.example.com
API_DOMAIN=api.example.com
PUBLIC_API_URL=https://api.example.com
ACME_EMAIL=admin@example.com

# Database container credentials. Change these before deploy.
POSTGRES_DB=koga_mdm
POSTGRES_USER=koga
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
DATABASE_URL=postgresql://koga:CHANGE_ME_LONG_RANDOM_DB_PASSWORD@postgres:5432/koga_mdm

# Redis. docker-compose sets redis://redis:6379 automatically for containers.
REDIS_URL=redis://redis:6379

# Bootstrap admin/platform owner. Use a strong email/password.
ORG_NAME=KOGA Platform
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=CHANGE_ME_MIN_12_CHARS
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
CRON_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
WEBHOOK_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET

# CORS. Use comma separated origins.
ALLOWED_ORIGINS=https://app.example.com,https://customer.example.com,https://api.example.com

# Storage provider. For pilot use local. For production use r2/s3/supabase.
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=/app/uploads
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Store/customer payment settings.
PROMPTPAY_ID=
PAYMENT_PROVIDER=manual
PAYMENT_GATEWAY_API_URL=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
SLIP_VERIFICATION_PROVIDER=manual
SLIP_VERIFICATION_API_URL=
SLIP_VERIFICATION_API_KEY=

# Notifications.
NOTIFICATION_PROVIDER=local
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
SMS_PROVIDER=disabled
SMS_API_URL=
SMS_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# Android Management API.
DEVICE_CONTROL_PROVIDER=mock
ANDROID_MANAGEMENT_PROJECT_ID=
ANDROID_MANAGEMENT_ENTERPRISE_NAME=
ANDROID_MANAGEMENT_SERVICE_ACCOUNT_JSON=/app/certs/google-service-account.json
ANDROID_WEBHOOK_SECRET=

# Apple MDM / ABM / ADE.
APPLE_MDM_BASE_URL=https://api.example.com
APPLE_MDM_APNS_CERT_PATH=/app/certs/apple-mdm-apns.pem
APPLE_MDM_APNS_KEY_PATH=/app/certs/apple-mdm-apns-key.pem
APPLE_MDM_APNS_TOPIC=
APPLE_ABM_SERVER_TOKEN_PATH=/app/certs/apple-abm-server-token.p7m
APPLE_MDM_PROFILE_SIGNING_CERT_PATH=/app/certs/profile-signing.pem
APPLE_MDM_PROFILE_SIGNING_KEY_PATH=/app/certs/profile-signing-key.pem
APPLE_SIGN_MOBILECONFIG=false

# Feature flags.
PORTAL_LEGACY_LOOKUP_ENABLED=false
